{
  "permissions": {
    "allow": [
      "Bash",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/stop_lock_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/override_token_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/docs_location_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/strict_code_gate.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/claude_md_protection.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/domain_pattern_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/plan_validator.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/post_implementation_gate.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/red_test_gate.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/scope_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/spec_enforcement.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/tdd_enforcement.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/track_changes.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/ui_screenshot_gate.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/workflow_gate.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/ui_test_preflight.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/sim_enforcer.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/build_lock_guard.py",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/stop_lock_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/override_token_bash_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/adversary_verdict_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre_commit_gate.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/secrets_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/test_lock_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/parallel_test_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/no_workaround_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Grep|Glob|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/visual_inspection_gate.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/feature_understanding_gate.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/build_lock_release.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/stop_lock_listener.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/workflow_state_updater.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/override_token_listener.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/workflow_cleanup.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}